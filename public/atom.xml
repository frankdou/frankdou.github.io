    <content type="html"><![CDATA[<blockquote class="blockquote-center">阿拉伯浮点数字转换成中文数字</blockquote>

<figure class="highlight javascript"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div><div class="line">5</div><div class="line">6</div><div class="line">7</div><div class="line">8</div><div class="line">9</div><div class="line">10</div><div class="line">11</div><div class="line">12</div><div class="line">13</div><div class="line">14</div><div class="line">15</div><div class="line">16</div><div class="line">17</div><div class="line">18</div><div class="line">19</div><div class="line">20</div><div class="line">21</div><div class="line">22</div><div class="line">23</div><div class="line">24</div><div class="line">25</div><div class="line">26</div><div class="line">27</div><div class="line">28</div><div class="line">29</div><div class="line">30</div><div class="line">31</div><div class="line">32</div><div class="line">33</div><div class="line">34</div><div class="line">35</div><div class="line">36</div><div class="line">37</div><div class="line">38</div><div class="line">39</div><div class="line">40</div><div class="line">41</div></pre></td><td class="code"><pre><div class="line"><span class="keyword">var</span> nNum = <span class="number">5566555234.123</span>,</div><div class="line">    sNum = nNum.toString(),</div><div class="line">    aNum = sNum.split(<span class="string">'.'</span>),</div><div class="line">    sNum = &#123;</div><div class="line">        <span class="string">'0'</span>: <span class="string">'零'</span>,</div><div class="line">        <span class="string">'1'</span>: <span class="string">'一'</span>,</div><div class="line">        <span class="string">'2'</span>: <span class="string">'二'</span>,</div><div class="line">        <span class="string">'3'</span>: <span class="string">'三'</span>,</div><div class="line">        <span class="string">'4'</span>: <span class="string">'四'</span>,</div><div class="line">        <span class="string">'5'</span>: <span class="string">'五'</span>,</div><div class="line">        <span class="string">'6'</span>: <span class="string">'六'</span>,</div><div class="line">        <span class="string">'7'</span>: <span class="string">'七'</span>,</div><div class="line">        <span class="string">'8'</span>: <span class="string">'八'</span>,</div><div class="line">        <span class="string">'9'</span>: <span class="string">'九'</span>,</div><div class="line">        <span class="string">'10'</span>: <span class="string">'十'</span></div><div class="line">    &#125;,</div><div class="line">    aInterger = [<span class="string">"元"</span>, <span class="string">"十"</span>, <span class="string">"百"</span>, <span class="string">"千"</span>, <span class="string">"万"</span>, <span class="string">"十"</span>, <span class="string">"百"</span>, <span class="string">"千"</span>, <span class="string">"亿"</span>, <span class="string">"十"</span>],</div><div class="line">    aPoint = [<span class="string">'毛'</span>, <span class="string">'分'</span>, <span class="string">'里'</span>],</div><div class="line">    sTmp = <span class="string">''</span>;</div><div class="line"></div><div class="line"></div><div class="line"><span class="keyword">for</span> (<span class="keyword">var</span> i = <span class="number">0</span>; i &lt; aNum.length; i++) &#123;</div><div class="line">    <span class="keyword">var</span> nSize = aNum[i].length;</div><div class="line"></div><div class="line">    <span class="keyword">if</span> (!i) &#123;</div><div class="line">        aInterger.length = nSize;</div><div class="line">        aInterger.reverse()</div><div class="line">    &#125;</div><div class="line"></div><div class="line">    <span class="keyword">for</span> (<span class="keyword">var</span> n = <span class="number">0</span>; n &lt; nSize; n++) &#123;</div><div class="line">        sTmp += sNum[aNum[i][n]];</div><div class="line"></div><div class="line">        <span class="keyword">if</span> (i) &#123;</div><div class="line">            sTmp += aPoint[n];</div><div class="line">        &#125; <span class="keyword">else</span> &#123;</div><div class="line">            sTmp += aInterger[n];</div><div class="line">        &#125;</div><div class="line">    &#125;</div><div class="line">&#125;</div><div class="line"></div><div class="line"><span class="built_in">console</span>.log(sTmp);</div></pre></td></tr></table></figure>
]]></content>
    
